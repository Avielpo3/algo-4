flowchart TB
  %% Algo 4 Cloud Gateway - Internal Pipeline

  %% === INGRESS (External → Algo) ===

  subgraph Sources["External Sources"]
    direction LR
    DaaS["DaaS Gateway<br/>(3PL callbacks)"]:::ext
    Proxy["Proxy Service<br/>(in-house courier events)"]:::ext
    Admin["Admin Panel UI"]:::ext
  end

  subgraph CGW["Cloud Gateway — Ingress Pipeline"]
    direction TB
    Intake["HTTP Intake"]
    Auth{"Authenticated?"}
    Validate{"Valid request?"}
    Adapter["Adapter<br/>(normalize to Kafka event)"]
    Producer["Kafka Producer"]
  end

  DaaS -->|"HTTP callback"| Intake
  Proxy -->|"HTTP event"| Intake
  Admin -->|"HTTPS REST"| Intake

  Intake --> Auth
  Auth -->|"yes"| Validate
  Auth -->|"no → 401 Unauthorized"| DaaS
  Auth -->|"no → 401 Unauthorized"| Proxy
  Auth -->|"no → 401 Unauthorized"| Admin
  Validate -->|"yes → 202 Accepted"| Adapter
  Validate -->|"no → 400 Bad Request"| DaaS
  Validate -->|"no → 400 Bad Request"| Proxy
  Validate -->|"no → 400 Bad Request"| Admin
  Adapter --> Producer

  %% --- Kafka ---
  subgraph Kafka["Internal Kafka"]
    direction LR
    Topics[("Business Topics")]
    Retry[("Retry Topic")]
    DLQ[("Dead Letter Topic")]
    Retry -->|"exhausted"| DLQ
  end

  Producer -->|"publish"| Topics
  Producer -->|"publish failed"| Retry
  Retry -->|"retry"| Producer

  %% --- Consumers ---
  Consumers["Algo 4 Services<br/>Order Mgmt · Dispatch · Promise Time · Customer"]:::svc
  Topics --> Consumers

  %% === EGRESS (Algo → External) ===
  %% Two mutually exclusive flows per order

  Consumers -->|"publish"| Topics

  subgraph EgressCGW["Cloud Gateway — Egress Pipeline"]
    direction TB
    EgressConsumer["Kafka Consumer"]
    EgressRoute{"Delivery type?"}
    DaasAdapter["DaaS Adapter<br/>(build HTTP body)"]
    MobileAdapter["Mobile Adapter<br/>(build PsEvent)"]
  end

  Topics -->|"consume"| EgressConsumer
  EgressConsumer --> EgressRoute

  EgressRoute -->|"3PL order<br/>(mutually exclusive)"| DaasAdapter
  EgressRoute -->|"In-house order<br/>(mutually exclusive)"| MobileAdapter

  DaasAdapter -->|"HTTP POST<br/>quotes · deliveries · cancel"| DaaS
  MobileAdapter -->|"HTTP<br/>PsEvent payload"| Proxy

  Proxy <-->|"WebSocket<br/>(unchanged)"| Mobile["DragonDrive<br/>(Mobile)"]:::device

  %% --- Audit ---
  Audit[("Audit Service")]:::audit
  Adapter -.->|"RECEIVED / NORMALIZED"| Audit
  Producer -.->|"PUBLISHED / PUBLISH_FAILED"| Audit
  DaasAdapter -.->|"DISPATCHED / FAILED"| Audit
  MobileAdapter -.->|"DISPATCHED / FAILED"| Audit

  %% --- Styles ---
  classDef ext fill:#E3F2FD,stroke:#1565C0,stroke-width:1px,color:#0D47A1
  classDef device fill:#E8F5E9,stroke:#2E7D32,stroke-width:1px,color:#1B5E20
  classDef gw fill:#FFFDE7,stroke:#F9A825,stroke-width:1px,color:#F57F17
  classDef audit fill:#FFF3E0,stroke:#EF6C00,stroke-width:1px,color:#E65100
  classDef kafka fill:#F3E5F5,stroke:#6A1B9A,stroke-width:1px,color:#4A148C
  classDef svc fill:#ECEFF1,stroke:#455A64,stroke-width:1px,color:#263238

  class Intake,Auth,Validate,Adapter,Producer gw
  class EgressConsumer,EgressRoute,DaasAdapter,MobileAdapter gw
  class Topics,Retry,DLQ kafka
